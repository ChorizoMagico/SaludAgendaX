# URL base del backend Django (incluye el prefijo /api)
VITE_API_URL=http://localhost:8000/api

# "true" (por defecto si se omite) = usa mockData.jsx, sin backend real.
# "false" = AuthContext usa el backend real para login/registro de PACIENTE.
# Los demás roles (medico/administrativo/superadministrador) siguen en mock
# porque el backend todavía no tiene esos flujos (ver resumen de la tarea).
VITE_USE_MOCK=true
