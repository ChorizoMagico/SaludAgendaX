# Copia este archivo a ".env" (que ya está en .gitignore) y coloca aquí tus
# valores reales. NUNCA subas el .env real al repositorio.

SECRET_KEY=cambia-esto-por-una-clave-secreta-nueva
DEBUG=True

# Backend de email: en desarrollo usa 'console' para ver los correos en la
# terminal sin enviar nada real. En producción usa 'smtp'.
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=tu_correo@dominio.com
EMAIL_HOST_PASSWORD=tu_app_password_de_gmail
DEFAULT_FROM_EMAIL=tu_correo@dominio.com
